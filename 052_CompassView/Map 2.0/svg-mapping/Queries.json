[out:json][timeout:50];

// Bounding box around Boston + harbor + Charles River
(
  // Standard water polygons
  way["natural"="water"](42.30,-71.10,42.40,-70.95);
  relation["natural"="water"](42.30,-71.10,42.40,-70.95);

  // Riverbanks
  way["waterway"="riverbank"](42.30,-71.10,42.40,-70.95);
  relation["waterway"="riverbank"](42.30,-71.10,42.40,-70.95);

  // Small lakes / ponds
  way["water"~"pond|lake|river"](42.30,-71.10,42.40,-70.95);
  relation["water"~"pond|lake|river"](42.30,-71.10,42.40,-70.95);
);
out geom;